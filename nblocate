. "${0%/*}/locate-lib"

# rclone lsl munge date|size_hex|path — same generation as oblocate hybrid
# era sibling tooling; no earlier format commits in this repo (added 2026-07-16).
apichangedate=1758567522
locate_bootstrap 5 1024 "$apichangedate"
dbname=allnbsd.database
cachedir=$HOME/.cache/${me}

cd $datadir || exit 1

while [ "$1" ]
do
	case "$1" in
	-B) build=1;;
	-v) let verbose=verbose+1;;
	*) break;;
	esac
	shift
done

if [ build -eq 0 ]; then
	locate_search_one "$@"
fi

pidfile_acquire
mkdir -p $cachedir

compress() {
	xz -9
}
rclone_lsrmt() {
	local rmt="$1" rdir="$2"
	rclone lsd $rmt:"$rdir" | \
		awk -v rdir="$rdir" '{
			if (length(rdir)>0) {
				printf "%s/", rdir;
			}
			printf "%s/\n", $5, type
		}'
}

rclone_cache_dir() {
	local rmt="$1" rdir="$2"
	local d="$rdir"
	local dname="$(echo "$d"|sed 's,/,_,g')"
	local cfilebase="${dname}.xz"
	echo "caching rmt dir $d to cache/$cfilebase"
	rclone lsl $rmt:${d} 2> /dev/null | \
	rclone_mungeforlocate "$d" | \
	tmpwrite="${cachedir}/.${cfilebase}"
	compress > ${cachedir}/.${cfilebase} && \
	mv -f ${cachedir}/.${cfilebase} ${cachedir}/${cfilebase} || exit 1
	tmpwrite=""
}
	
rclone_mungeforlocate() {
	awk -v d="$1" '
		{
			gsub("-","",$2);
			gsub(":","",$3);
			gsub("\\.[0-9]+","",$3);
			printf "%s%s|%x|%s/%s\n",$2,$3,$1,d,$4;
		}'
}


# should be static, rm to refresh
for path in $(rclone_lsrmt nb-https | egrep "^NetBSD-[0-9][0-9]*.[0-9].*/$")
do
	cksys
	dname="$(echo "$path"|sed 's,/,_,g')"
	if ! [ -f "$cachedir/${dname}.xz" ]; then
		rclone_cache_dir nb-https "$path"
	fi
done

# list archs
for path in $(rclone_lsrmt nb-pkg-https)
do
	cksys
	echo "pkg-https $path>"
	for p2 in $(rclone_lsrmt nb-pkg-https $path)
	do
		ptmp="$path/$p2"
		echo "pkg-https $ptmp>"
		dname="$(echo "$ptmp"|sed 's,/,_,g')"
		if ! [ -f $cachedir/${dname}.xz ]; then
			rclone_cache_dir nb-pkg-https "$ptmp"
		fi
		exit 1
	done
done

# update each time
for path in {arch,NetBSD-{current,daily,release*},images,install-images,iso,misc,packages,releng,security,torrent}
do
	cksys
	rclone_cache_dir nb-https "$path"
done 
for path in $(rclone_lsrmt nb-https NetBSD-archive/)
do
	cksys
	dname="$(echo "$path"|sed 's,/,_,g')"
	if ! [ -f $cachedir/NetBSD-archive_${dname}.xz ]; then
		rclone_cache_dir nb-https "NetBSD-archive/$path"
	fi
done

cksys
tmpwrite=".$dbname"
xzcat $cachedir/*.xz | \
	$sort -u | \
	/usr/libexec/locate.mklocatedb > .$dbname && \
	mv -f .$dbname $dbname
tmpwrite=""
