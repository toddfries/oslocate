. "${0%/*}/locate-lib"
. "${0%/*}/osmirror-lib"

# rclone lsl munge date|size_hex|path — same generation as oblocate hybrid
# era sibling tooling; no earlier format commits in this repo (added 2026-07-16).
apichangedate=1758567522
locate_bootstrap 5 1024 "$apichangedate"
dbname=allnbsd.database
cachedir=$HOME/.cache/${me}

# rclone remote names (see rclone.conf); layout differs from OpenBSD/oblocate.
nb_release_rmt=${NB_RELEASE_RMT:-nb-https}
nb_pkg_rmt=${NB_PKG_RMT:-nb-pkg-https}

cd $datadir || exit 1

while [ "$1" ]
do
	case "$1" in
	-B) build=1;;
	-v) let verbose=verbose+1;;
	*) break;;
	esac
	shift
done

if [ build -eq 0 ]; then
	locate_search_one "$@"
fi

pidfile_acquire
mkdir -p $cachedir

# Thin wrappers → osmirror-lib (multi-remote NetBSD)
rclone_lsrmt() {
	osmirror_rclone_lsrmt "$1" "$2"
}
rclone_cache_dir() {
	osmirror_rclone_cache_dir "$1" "$2" || exit 1
}

# ---------------------------------------------------------------------------
# NetBSD mirror walk (layout-specific config)
# ---------------------------------------------------------------------------

# Release trees (static once cached; rm shard to refresh)
for d in $(rclone_lsrmt "$nb_release_rmt" | egrep "^NetBSD-[0-9][0-9]*\.[0-9]")
do
	cksys
	d=${d%/}
	dname=$(osmirror_path_to_dname "$d")
	if ! [ -f "$cachedir/${dname}.xz" ]; then
		rclone_cache_dir "$nb_release_rmt" "$d"
	fi
done

# Package sets: two-level walk under nb-pkg-https
for d in $(rclone_lsrmt "$nb_pkg_rmt")
do
	cksys
	d=${d%/}
	echo "pkg-https $d>"
	for p2 in $(rclone_lsrmt "$nb_pkg_rmt" "$d")
	do
		cksys
		p2=${p2%/}
		ptmp="$d/$p2"
		echo "pkg-https $ptmp>"
		dname=$(osmirror_path_to_dname "$ptmp")
		if ! [ -f "$cachedir/${dname}.xz" ]; then
			rclone_cache_dir "$nb_pkg_rmt" "$ptmp"
		fi
	done
done

# Volatile top-level dirs (refresh every -B)
for path in arch NetBSD-current NetBSD-daily images install-images \
	iso misc packages releng security torrent
do
	cksys
	rclone_cache_dir "$nb_release_rmt" "$path"
done
for path in $(rclone_lsrmt "$nb_release_rmt" | egrep '^NetBSD-release')
do
	cksys
	path=${path%/}
	rclone_cache_dir "$nb_release_rmt" "$path"
done

# Historic archive (static shards)
for d in $(rclone_lsrmt "$nb_release_rmt" NetBSD-archive)
do
	cksys
	d=${d%/}
	dname=$(osmirror_path_to_dname "NetBSD-archive_${d}")
	if ! [ -f "$cachedir/${dname}.xz" ]; then
		rclone_cache_dir "$nb_release_rmt" "NetBSD-archive/$d"
	fi
done

# Assemble (tmpwrite for trap cleanup)
cksys
osmirror_assemble_db "$dbname"
